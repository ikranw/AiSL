# Copy this file to .env and fill in your values.
# .env is gitignored – never commit real secrets.

# Required for live ASL translations.
# Without this key the server runs in mock/demo mode (hardcoded responses).
OPENAI_API_KEY=sk-...

# Optional – defaults to gpt-4o-mini if not set.
# OPENAI_MODEL=gpt-4o-mini

# Kaggle API credentials – required for downloading datasets via the Kaggle API.
# Find these at https://www.kaggle.com/settings → "API" → "Create New Token".
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key
