# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/Assets/AssetStoreTools/
/UserSettings/
/Logs/
.unitypackagetoexport
.symlnk
unitycloud_build_temp_dir/

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/MonoDevelop solution and project files
/*.csd
/*.rsp
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.csproj.meta
*.ghw
*.map
*.net
*.safe
*.opensdf
*.sdf
*.vst
*.vnf

# Unity-generated text meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity-generated binary meta files
*.dll.meta
*.asmdef.meta

# Visual Studio files
*.csproj

# Memory Captures
# MemoryCaptures can get excessive in size.
*.mcap

# Uncomment this at your own peril, b/c it will ignore the asset created by Unity,
# for this you need to have your project settings correct
# # Uncomment to ignore the Assets/AssetImportPipeline directory
# # /Assets/AssetImportPipeline

# Unity test runner artifacts
/Assets/Resources/PerformanceTestRunInfo.json
/Assets/Resources/PerformanceTestRunInfo.json.meta
/Assets/Resources/PerformanceTestRunSettings.json
/Assets/Resources/PerformanceTestRunSettings.json.meta

# Misc
*.stackdump
